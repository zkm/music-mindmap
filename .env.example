# Required: Navidrome connection
NAVIDROME_URL=http://navipi:4533
NAVIDROME_USER=your_username
NAVIDROME_PASSWORD=your_password
# Optional, defaults to "music-mindmap"
NAVIDROME_CLIENT=music-mindmap

# Optional: MusicBrainz lookups for the `region` tag category.
# Must be a contact string per MB policy. Leave blank to disable MB.
MB_USER_AGENT=music-mindmap/0.1 ( your.email@example.com )

# Optional: LLM fallback for tag-sparse artists. Leave all blank to disable.
# Pick exactly one provider:
LLM_PROVIDER=
# When LLM_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
# When LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# When LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Server
SERVER_PORT=8787
# Preview transcoding via Navidrome
PREVIEW_FORMAT=mp3
PREVIEW_BITRATE=128

# Optional: local mirror of the Navidrome library for the v2 audio sidecar.
LOCAL_MUSIC_ROOT=/mnt/zombie/NapsterX/Music
